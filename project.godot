; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="claw-machine"
run/main_scene="res://menu/main_menu.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://icon.svg"
boot_splash/bg_color=Color(0.10980392, 0.12156863, 0.14901961, 1)
boot_splash/image="res://assets/branding/molten_unicorn_splash.png"
boot_splash/stretch_mode=0
boot_splash/use_filter=true

[autoload]

GameState="*uid://dtcit4mxtnt0c"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="claw-machine"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
